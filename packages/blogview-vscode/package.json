{
  "name": "blogview-vscode",
  "displayName": "Blogview",
  "publisher": "mkizka",
  "private": true,
  "description": "Markdownプレビュー時に一部のはてな記法を変換する拡張機能",
  "version": "1.5.3",
  "engines": {
    "vscode": "^1.67.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:/entry/"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.js",
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./tweet.js"
    ],
    "views": {
      "explorer": [
        {
          "id": "blogview",
          "name": "記事一覧",
          "when": "blogview-vscode.activated"
        }
      ]
    },
    "configuration": {
      "title": "Blogview",
      "properties": {
        "blogview.enableTwitter": {
          "type": "boolean",
          "description": "ツイート埋め込みを有効化(再起動後に反映)",
          "default": true
        },
        "blogview.enableYoutube": {
          "type": "boolean",
          "description": "YouTube埋め込みを有効化(再起動後に反映)",
          "default": true
        }
      }
    }
  },
  "scripts": {
    "build": "node build.js",
    "dev": "nodemon",
    "package": "pnpm vsce package --no-dependencies",
    "release": "pnpm vsce publish --no-dependencies",
    "test-vscode": "tsc -p tsconfig.test.json && node --enable-source-maps dist-test/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "~25.9.1",
    "@types/vscode": "1.120.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "mocha": "^11.7.6",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "markdown-it-hatena": "workspace:*"
  },
  "keywords": [
    "markdown",
    "blog",
    "hatena"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mkizka/blogview.git"
  },
  "bugs": {
    "url": "https://github.com/mkizka/blogview/issues"
  },
  "homepage": "https://github.com/mkizka/blogview",
  "license": "MIT"
}
